# ════════════════════════════════════════════════════
#  CTFd — Servidor, NUNCA llega al browser
# ════════════════════════════════════════════════════

# URL base del API de CTFd en tu VPS
CTFD_BASE_URL=

# Token de administrador de CTFd
CTFD_ADMIN_TOKEN=

# ID numérico del custom field de usuario (ej. is_tec_campus)
CTFD_TEC_CAMPUS_FIELD_ID=

# IDs numéricos opcionales para mapear campos extendidos de registro
CTFD_FIRST_NAME_FIELD_ID=
CTFD_LAST_NAME_FIELD_ID=
CTFD_AGE_FIELD_ID=
CTFD_PHONE_FIELD_ID=
CTFD_MATRICULA_FIELD_ID=
CTFD_COUNTRY_FIELD_ID=
CTFD_CAREER_FIELD_ID=
CTFD_STUDY_LEVEL_FIELD_ID=
CTFD_CTFS_ATTENDED_FIELD_ID=
CTFD_SHIRT_SIZE_FIELD_ID=
CTFD_HEARD_FROM_FIELD_ID=
CTFD_EMERGENCY_NAME_FIELD_ID=
CTFD_EMERGENCY_RELATION_FIELD_ID=
CTFD_EMERGENCY_PHONE_FIELD_ID=
CTFD_EMERGENCY_EMAIL_FIELD_ID=

# ════════════════════════════════════════════════════
#  Sesión (iron-session) — Servidor, NUNCA al browser
# ════════════════════════════════════════════════════

# Clave de encriptación de las cookies de sesión
SESSION_SECRET=

# ════════════════════════════════════════════════════
#  Nginx — Servidor, NUNCA al browser
# ════════════════════════════════════════════════════

# Secreto compartido entre Vercel y tu Nginx en el VPS
NGINX_INTERNAL_SECRET=

# ════════════════════════════════════════════════════
#  Públicas — Se incrustan en el JS del browser (solo info pública)
# ════════════════════════════════════════════════════

# URL del servidor de Discord (es pública de todas formas)
NEXT_PUBLIC_DISCORD_URL=
NEXT_PUBLIC_LINKEDIN_URL=
NEXT_PUBLIC_GITHUB_URL=
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_MAILTO_URL=