# In this file you can define environment variables for your application.
# Copy this file to .env and modify the values as needed.

# Application environment

# CTF timing (ISO 8601)
NEXT_PUBLIC_CTF_START=2026-05-09T21:00:00Z
NEXT_PUBLIC_CTF_END=2026-05-10T07:00:00Z

# CTFd API (server-side route handlers)
# If not defined, routes fall back to mock data.
CTFD_API_URL=
CTFD_API_TOKEN=