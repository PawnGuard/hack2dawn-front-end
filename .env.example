# ════════════════════════════════════════════════════
#  CTFd — Servidor, NUNCA llega al browser
# ════════════════════════════════════════════════════

# URL base del API de CTFd en tu VPS
CTFD_BASE_URL=

# Token de administrador de CTFd
CTFD_ADMIN_TOKEN=

# ════════════════════════════════════════════════════
#  Sesión (iron-session) — Servidor, NUNCA al browser
# ════════════════════════════════════════════════════

# Clave de encriptación de las cookies de sesión
SESSION_SECRET=

# ════════════════════════════════════════════════════
#  Nginx — Servidor, NUNCA al browser
# ════════════════════════════════════════════════════

# Secreto compartido entre Vercel y tu Nginx en el VPS
NGINX_INTERNAL_SECRET=

# ════════════════════════════════════════════════════
#  Públicas — Se incrustan en el JS del browser (solo info pública)
# ════════════════════════════════════════════════════

# URL del servidor de Discord (es pública de todas formas)
NEXT_PUBLIC_DISCORD_URL=
NEXT_PUBLIC_LINKEDIN_URL=
NEXT_PUBLIC_GITHUB_URL=
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_MAILTO_URL=